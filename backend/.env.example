# ── Base de datos
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cropsight

# ── JWT
SECRET_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_IMAGES=cropsight-images
S3_BUCKET_MODELS=cropsight-models

# ── Inferencia Lambda
LAMBDA_INFERENCE_URL=https://xxxxx.execute-api.us-east-1.amazonaws.com/inference

# ── MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=cropsight-classifier

# ── GitHub Actions (retraining trigger)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=org/cropsight
GITHUB_WORKFLOW_ID=retraining.yml

# ── Entorno
ENVIRONMENT=development
