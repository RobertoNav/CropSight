# MLflow tracking server URI (local default for development)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Registry stage to serve from. Use "Staging" for pre-prod, "Production" for prod.
MLFLOW_MODEL_STAGE=Production

# Comma-separated crops the inference service will load on startup
CROPS=tomato,potato,corn,grape

# AWS credentials — only needed when MLflow uses an S3 artifact store
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# MLFLOW_S3_ENDPOINT_URL=
